# Variables de entorno del SERVIDOR (nunca expuestas al navegador).
# Copia este archivo a .env (local) y configúralas en Vercel → Settings → Environment Variables.

# OpenRouter — clasificador + OCR doble. NO usar prefijo VITE_ (la expondría al cliente).
OPENROUTER_API_KEY=tu_api_key_de_openrouter

# (Más adelante) Google OAuth para Gmail readonly y Sheets/Drive
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
