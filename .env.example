# Variables de entorno del SERVIDOR (nunca expuestas al navegador).
# Copia a .env (local) y configúralas también en Vercel → Settings → Environment Variables.
# Ninguna lleva prefijo VITE_ (eso las expondría al cliente).

# OpenRouter — clasificador + OCR doble
OPENROUTER_API_KEY=tu_api_key_de_openrouter

# n8n — motor de captura (crear credenciales IMAP por API)
N8N_BASE_URL=https://tu-instancia.n8n.cloud
N8N_API_KEY=tu_api_key_de_n8n

# Google OAuth — almacenamiento en Drive del contador (scope drive.file)
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
